# Nimbus configuration template.
# Copy to .env and fill in real values. .env is gitignored.

# Proxmox API endpoint and credentials.
# - On a Proxmox host install: use https://localhost:8006
# - On a guest VM or external machine: use a cluster node's IP/hostname
PROXMOX_HOST=https://localhost:8006

# Token format: user@realm!tokenname (the secret comes separately).
# Create in the Proxmox UI: Datacenter → Permissions → API Tokens → Add
# Make sure to UNCHECK "Privilege Separation" or the token won't work.
PROXMOX_TOKEN_ID=root@pam!nimbus
PROXMOX_TOKEN_SECRET=replace-with-uuid-shown-once

# OS template VMID base. Templates are at base+0..base+3 for the four supported OSes.
PROXMOX_TEMPLATE_BASE_VMID=9000

# Optional: comma-separated node names to exclude from scoring.
NIMBUS_EXCLUDED_NODES=

# IP pool — every IP in this inclusive range is available to provision.
IP_POOL_START=192.168.0.100
IP_POOL_END=192.168.0.199
GATEWAY_IP=192.168.0.1

# Optional cloud-init defaults.
NAMESERVER=1.1.1.1 8.8.8.8
SEARCH_DOMAIN=local

# HTTP server.
PORT=8080
DB_PATH=./nimbus.db

# Phase 2/3 placeholders (unused in Phase 1).
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=
# GOPHER_API_URL=
# GOPHER_API_KEY=
