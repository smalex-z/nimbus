# Go
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
nimbus
nimbus-linux-*
nimbus-darwin-*
nimbus-windows-*

# GX10 worker binary — produced by `make gx10-worker`, served at runtime
# via /api/gpu/scripts/gx10-worker. Build artifact; production deploys
# should run `make gx10-worker` before packaging.
scripts/gx10/gx10-worker

# GX10 asset bundle — populated by `make gx10-bundle` (or by the build
# pipeline before `go build`). Mirrors the cmd/server/frontend/dist
# pattern: directory must exist at compile time for the //go:embed
# directive in main.go, but its contents are build artifacts.
cmd/server/gx10-assets/*
!cmd/server/gx10-assets/.gitkeep

# Frontend
frontend/node_modules/
frontend/dist/
frontend/.npm-cache/

# Embedded dist (built output goes here). The directory is required at
# `go build` time by `//go:embed all:frontend/dist` — we keep it in git via
# .gitkeep but ignore every actual build artifact, so frontend rebuilds don't
# show up in git status / cause merge conflicts.
cmd/server/frontend/dist/*
!cmd/server/frontend/dist/.gitkeep

# Database
*.db
*.db-shm
*.db-wal

# Environment / secrets — NEVER commit these
.env
.env.*
!.env.example

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

.env
