# Go
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
nimbus
nimbus-linux-*
nimbus-darwin-*
nimbus-windows-*

# Frontend
frontend/node_modules/
frontend/dist/
frontend/.npm-cache/

# Embedded dist (built output goes here). The directory is required at
# `go build` time by `//go:embed all:frontend/dist` — we keep it in git via
# .gitkeep but ignore every actual build artifact, so frontend rebuilds don't
# show up in git status / cause merge conflicts.
cmd/server/frontend/dist/*
!cmd/server/frontend/dist/.gitkeep

# Database
*.db
*.db-shm
*.db-wal

# Environment / secrets — NEVER commit these
.env
.env.*
!.env.example

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

.env
